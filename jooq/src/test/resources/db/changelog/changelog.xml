<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="1" author="yourname">
        <createTable tableName="test_table">
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="age" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Field Validation tables -->
    <changeSet id="2" author="vortex-crud">
        <createTable tableName="validation_test">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="required_field" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email_field" type="VARCHAR(255)"/>
            <column name="numeric_field" type="REAL"/>
            <column name="date_field" type="DATE"/>
            <column name="enum_field" type="VARCHAR(20)"/>
        </createTable>
    </changeSet>

    <!-- Many-to-Many tables -->
    <changeSet id="3" author="vortex-crud">
        <createTable tableName="many_to_many_item">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="vortex-crud">
        <createTable tableName="many_to_many_item_relation">
            <column name="item_id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_many_to_many_item_relation"
                             foreignKeyName="fk_mtm_item" references="many_to_many_item(id)"/>
            </column>
            <column name="related_item_id" type="INTEGER">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_many_to_many_item_relation"
                             foreignKeyName="fk_mtm_related_item" references="many_to_many_item(id)"/>
            </column>
        </createTable>
    </changeSet>

    <!-- One-to-Many tables -->
    <changeSet id="5" author="vortex-crud">
        <createTable tableName="one_to_many_parent">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="6" author="vortex-crud">
        <createTable tableName="one_to_many_child">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="INTEGER">
                <constraints nullable="true" foreignKeyName="fk_otm_parent" references="one_to_many_parent(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>